# Local-only defaults. Replace every credential before production.
ASPNETCORE_ENVIRONMENT=Development
SEED_DEMO_DATA=true
DATABASE_CONNECTION_STRING=Host=postgres;Port=5432;Database=vaultshare;Username=vaultshare;Password=local-only-change-me
POSTGRES_DB=vaultshare
POSTGRES_USER=vaultshare
POSTGRES_PASSWORD=local-only-change-me
OBJECT_STORAGE_ENDPOINT=minio:9000
OBJECT_STORAGE_ACCESS_KEY=vaultshare-local
OBJECT_STORAGE_SECRET_KEY=local-only-change-me
OBJECT_STORAGE_BUCKET=vaultshare-encrypted
OBJECT_STORAGE_USE_SSL=false
# Generate with: openssl rand -base64 32
FILE_ENCRYPTION_KEK=REPLACE_WITH_BASE64_32_BYTE_KEY
FILE_ENCRYPTION_KEY_ID=local-kek-v1
# Only set during a controlled rewrap command; never pass KEKs as CLI arguments.
FILE_ENCRYPTION_KEK_NEXT=
FILE_ENCRYPTION_KEY_ID_NEXT=
# Generate independently with: openssl rand -base64 32
PRIVACY_IP_HASH_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY
MAX_UPLOAD_SIZE=1073741824
WORKSPACE_DEFAULT_QUOTA=10737418240
TEMP_UPLOAD_PATH=/var/lib/vaultshare/uploads
TEMP_FILE_RETENTION=01:00:00
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_FAIL_CLOSED=true
PUBLIC_APP_URL=http://localhost:8080
API_URL=http://api:8080
NEXT_PUBLIC_API_URL=http://localhost:8080
FRONTEND_URL=http://frontend:3000
COOKIE_DOMAIN=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=false
EMAIL_FROM=VaultShare <no-reply@localhost>
SHARE_DEFAULT_EXPIRATION=7.00:00:00
SHARE_MAX_EXPIRATION=30.00:00:00
AUDIT_RETENTION_DAYS=365
ACCESS_ATTEMPT_RETENTION_DAYS=90
NOTIFICATION_RETENTION_DAYS=90
PROCESSING_STALE_AFTER=01:00:00
WORKER_POLL_INTERVAL=00:00:02
DELETED_FILE_GRACE_PERIOD=30.00:00:00
LOG_LEVEL=Information
